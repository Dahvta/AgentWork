# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AgentWork backend
VITE_AGENTWORK_API_URL="/api"
PORT="8080"
DATABASE_URL="postgresql://agentwork:agentwork@localhost:5432/agentwork?schema=public"
REDIS_URL="redis://localhost:6379"
ARC_RPC_HTTP_URL="https://rpc.arc.network"
ARC_RPC_WS_URL="wss://rpc.arc.network"
ARC_INDEX_FROM_BLOCK="0"
AGENT_REGISTRY_ADDRESS="0x0000000000000000000000000000000000000000"
JOB_LIFECYCLE_ADDRESS="0x0000000000000000000000000000000000000000"
SETTLEMENT_PRIVATE_KEY=""
PINATA_JWT=""
IPFS_GATEWAY_URL="https://ipfs.io/ipfs"

# Contract deployment
DEPLOYER="0x0000000000000000000000000000000000000000"
DEPLOYER_PRIVATE_KEY=""
USDC_ADDRESS="0x0000000000000000000000000000000000000000"
FEE_RECIPIENT="0x0000000000000000000000000000000000000000"
